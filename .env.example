# Unified LLM provider
# Production / paid delivery should point to your own paid provider.
AGENT_FACTORY_LLM_API_KEY=
AGENT_FACTORY_LLM_BASE_URL=
AGENT_FACTORY_LLM_MODEL=
AGENT_FACTORY_ALLOW_LOCAL_LLM_IN_PROD=

# 9router / local OpenAI-compatible router for development
AGENT_FACTORY_9ROUTER_API_KEY=
AGENT_FACTORY_9ROUTER_BASE_URL=http://localhost:20128/v1
AGENT_FACTORY_9ROUTER_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_API_KEY=
NINE_ROUTER_BASE_URL=http://localhost:20128/v1
NINE_ROUTER_MODEL=kr/claude-sonnet-4.5

# Industry research API auth
# Production must set this. Requests to /api/industry-research/run then need x-internal-key.
# Local development leaves it empty for convenience.
AGENT_FACTORY_INTERNAL_API_KEY=

# Supabase draft variables, not wired yet
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# n8n draft variables, not wired yet
N8N_WEBHOOK_BASE_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
