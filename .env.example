# OpenAI
OPENAI_API_KEY=

# 部署目标
# 生产环境固定为 lightweight_server；本机开发可留空。
AGENT_FACTORY_DEPLOYMENT_TARGET=
# 服务器手动运行 pnpm 脚本时可显式指定；默认也会尝试读取 /etc/industry-research/industry-research.env。
AGENT_FACTORY_ENV_FILE=

# 统一 LLM provider（audit P1-5 / P3-2）
# 生产 / 付费交付首选：指向你自付费的 provider（Anthropic / OpenAI / DeepSeek，
# 或其他 OpenAI-compatible provider）。设置后优先级高于下方 DeepSeek 变量。
# 生产环境若 base URL 仍是 localhost，会被拒绝（除非 AGENT_FACTORY_ALLOW_LOCAL_LLM_IN_PROD=1）。
AGENT_FACTORY_LLM_API_KEY=
AGENT_FACTORY_LLM_BASE_URL=
AGENT_FACTORY_LLM_MODEL=
AGENT_FACTORY_ALLOW_LOCAL_LLM_IN_PROD=

# DeepSeek v4 flash（当前行业研究默认真实 LLM）
AGENT_FACTORY_DEEPSEEK_API_KEY=
AGENT_FACTORY_DEEPSEEK_BASE_URL=https://api.deepseek.com
AGENT_FACTORY_DEEPSEEK_MODEL=deepseek-v4-flash
AGENT_FACTORY_DEEPSEEK_THINKING=disabled
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Legacy 9router / local OpenAI-compatible router（历史兼容，不再作为默认）
AGENT_FACTORY_9ROUTER_API_KEY=
AGENT_FACTORY_9ROUTER_BASE_URL=http://localhost:20128/v1
AGENT_FACTORY_9ROUTER_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_API_KEY=
NINE_ROUTER_BASE_URL=http://localhost:20128/v1
NINE_ROUTER_MODEL=kr/claude-sonnet-4.5

# Legacy GLM / 智谱 BigModel fallback
# 这些变量只用于历史记录，不作为 DeepSeek 默认配置。
AGENT_FACTORY_GLM_API_KEY=
AGENT_FACTORY_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AGENT_FACTORY_GLM_MODEL=glm-4.7-flash
FRIDGE_ZHIPU_API_KEY=
FRIDGE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 搜索发现 provider（可选）
# 推荐 tavily（免费档 1,000 credits/month、无需信用卡）或 serper（注册送 2,500 free queries）。
# 不配置时默认 duckduckgo_html 抓取；brave 仍保留兼容但不再推荐。
AGENT_FACTORY_SEARCH_PROVIDER=
AGENT_FACTORY_SEARCH_API_KEY=
AGENT_FACTORY_SEARCH_BASE_URL=

# 内容生态官方 API（可选；只走官方 API，不爬社媒页面）
# 配置后 public_web run 会补充 YouTube / Reddit 内容信号进 content/pain_point/keyword 库。
AGENT_FACTORY_YOUTUBE_API_KEY=
AGENT_FACTORY_REDDIT_ACCESS_TOKEN=

# Supabase，后续接入时再填写
AGENT_FACTORY_SUPABASE_ENABLED=false
AGENT_FACTORY_SUPABASE_PROJECT_REF=ghsyjdipofnyokbbbrdb
NEXT_PUBLIC_SUPABASE_URL=https://ghsyjdipofnyokbbbrdb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# zvec 本地检索缓存；不是权威存储，可删除重建
AGENT_FACTORY_ZVEC_ENABLED=false
AGENT_FACTORY_ZVEC_DIR=.cache/industry-research-zvec/chunks
AGENT_FACTORY_EMBEDDING_BASE_URL=
AGENT_FACTORY_EMBEDDING_API_KEY=
AGENT_FACTORY_EMBEDDING_MODEL=

# 行业研究本地 run 留档目录
# 本机默认读取 outputs/industry-research-runs；轻量服务器生产建议：
# /var/lib/industry-research/runs
AGENT_FACTORY_PERSIST_INDUSTRY_RESEARCH_RUNS=true
AGENT_FACTORY_INDUSTRY_RESEARCH_RUNS_DIR=

# n8n，后续接入时再填写
# 当前只预留 webhook 合约，不要求公网 n8n 可用。
AGENT_FACTORY_N8N_ENABLED=false
AGENT_FACTORY_N8N_WEBHOOK_BASE_URL=
AGENT_FACTORY_N8N_WEBHOOK_SECRET=
AGENT_FACTORY_N8N_RUN_COMPLETE_PATH=/api/industry-research/webhooks/n8n-run-complete
N8N_WEBHOOK_BASE_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENT_FACTORY_BASE_URL=http://localhost:3000

# 行业研究 API 鉴权（audit P0-2）
# 生产环境必须设置；设置后调用 /api/industry-research/run 需带请求头 x-internal-key。
# 本地开发留空时放行，便于调试。
AGENT_FACTORY_INTERNAL_API_KEY=
