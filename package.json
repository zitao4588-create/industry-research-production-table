{
  "name": "industry-research-production-table",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm dev:studio",
    "dev:studio": "pnpm --filter @industry-research/studio dev",
    "build": "pnpm --filter @industry-research/studio build",
