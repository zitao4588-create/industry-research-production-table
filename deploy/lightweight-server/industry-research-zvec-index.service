[Unit]
Description=Rebuild Industry Research zvec cache
After=industry-research.service

[Service]
Type=oneshot
User=industry-research
Group=industry-research
WorkingDirectory=/opt/industry-research-production-table
EnvironmentFile=/etc/industry-research/industry-research.env
ExecStart=/usr/bin/env bash -lc 'pnpm zvec:index'
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/industry-research
