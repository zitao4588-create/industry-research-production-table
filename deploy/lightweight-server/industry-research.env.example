# Copy to /etc/industry-research/industry-research.env on the lightweight server.
# Do not commit the real file.

NODE_ENV=production
PORT=3010
AGENT_FACTORY_DEPLOYMENT_TARGET=lightweight_server
AGENT_FACTORY_ENV_FILE=/etc/industry-research/industry-research.env

NEXT_PUBLIC_APP_URL=https://research.playgamelab.cn
AGENT_FACTORY_BASE_URL=https://research.playgamelab.cn

AGENT_FACTORY_INTERNAL_API_KEY=
AGENT_FACTORY_ALLOWED_ORIGINS=https://research.playgamelab.cn
AGENT_FACTORY_ALLOWED_HOSTS=research.playgamelab.cn
AGENT_FACTORY_RUN_TIMEOUT_MS=300000
AGENT_FACTORY_RUN_MAX_BODY_BYTES=256000
AGENT_FACTORY_MAX_RUNS_PER_IP_PER_HOUR=10
AGENT_FACTORY_N8N_ENABLED=true
AGENT_FACTORY_N8N_WEBHOOK_BASE_URL=https://n8n.playgamelab.cn/webhook
AGENT_FACTORY_N8N_WEBHOOK_SECRET=
AGENT_FACTORY_N8N_RUN_COMPLETE_PATH=/api/industry-research/webhooks/n8n-run-complete
N8N_WEBHOOK_BASE_URL=https://n8n.playgamelab.cn/webhook

AGENT_FACTORY_PERSIST_INDUSTRY_RESEARCH_RUNS=true
AGENT_FACTORY_INDUSTRY_RESEARCH_RUNS_DIR=/var/lib/industry-research/runs

AGENT_FACTORY_SUPABASE_ENABLED=true
AGENT_FACTORY_SUPABASE_PROJECT_REF=ghsyjdipofnyokbbbrdb
NEXT_PUBLIC_SUPABASE_URL=https://ghsyjdipofnyokbbbrdb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

AGENT_FACTORY_ZVEC_ENABLED=true
AGENT_FACTORY_ZVEC_DIR=/var/lib/industry-research/zvec/chunks
AGENT_FACTORY_ZVEC_STATE_FILE=/var/lib/industry-research/zvec/index-state.json
AGENT_FACTORY_ZVEC_SOURCE=auto

AGENT_FACTORY_LLM_API_KEY=
AGENT_FACTORY_LLM_BASE_URL=https://router.playgamelab.cn/v1
AGENT_FACTORY_LLM_MODEL=
AGENT_FACTORY_ALLOW_LOCAL_LLM_IN_PROD=

AGENT_FACTORY_SEARCH_PROVIDER=tavily
AGENT_FACTORY_SEARCH_API_KEY=
AGENT_FACTORY_SEARCH_BASE_URL=https://api.tavily.com/search

AGENT_FACTORY_SOURCE_REGISTRY_DISABLED=false
AGENT_FACTORY_FIXED_SOURCE_URLS=
AGENT_FACTORY_SOURCE_REGISTRY_JSON=

AGENT_FACTORY_PUBLIC_WEB_MAX_SEARCH_QUERIES=2
AGENT_FACTORY_PUBLIC_WEB_MAX_SEARCH_RESULTS_PER_QUERY=4
AGENT_FACTORY_PUBLIC_WEB_MAX_DISCOVERED_TARGETS=10
AGENT_FACTORY_PUBLIC_WEB_MAX_PROBE_URLS=8
AGENT_FACTORY_PUBLIC_WEB_MAX_SITEMAP_URLS=4
AGENT_FACTORY_PUBLIC_WEB_REQUEST_TIMEOUT_MS=8000
AGENT_FACTORY_PUBLIC_WEB_MAX_CRAWL_TARGETS=8

AGENT_FACTORY_FIRECRAWL_ENABLED=false
AGENT_FACTORY_FIRECRAWL_API_KEY=
AGENT_FACTORY_FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
AGENT_FACTORY_FIRECRAWL_TARGET_KINDS=homepage,collection,product,blog
AGENT_FACTORY_FIRECRAWL_TIMEOUT_MS=12000
FIRECRAWL_API_KEY=

AGENT_FACTORY_EMBEDDING_BASE_URL=
AGENT_FACTORY_EMBEDDING_API_KEY=
AGENT_FACTORY_EMBEDDING_MODEL=
